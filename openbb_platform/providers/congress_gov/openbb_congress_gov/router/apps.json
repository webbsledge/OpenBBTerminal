        {
          "i": "rich_note-ba4ed537-f663-4dea-be62-3513bee784a5",
          "x": 0,
          "y": 2,
          "w": 40,
          "h": 8,
          "state": {
            "storage": {
              "html": "<h2 style=\"text-align: left;\">How To Use</h2><p style=\"text-align: left;\">These widgets work the same way as three on the <strong>Bills</strong> tab.</p><p style=\"text-align: left;\">Click to the right of the \"Link\" in the Amendment URL column to change the loaded ammendment.</p><p style=\"text-align: left;\">With no Congress number, the 100 most recent amendments are surfaced. To filter them by type, you must enter a Congress number.</p><p style=\"text-align: left;\">Some amendments, like those from the Senate, reference Congressional Record text as the source, while others link to the bills themselves.</p><p style=\"text-align: left;\">On a working day, there may be hundreds of amendments appended to the same bill. Each amendment number is a unique record.</p>"
            }
          },
          "groups": []
        }
      ]
    },
    "committees": {
