        {
          "i": "rich_note-ab1c1d5a-f476-4dd9-b9be-88042eef2583",
          "x": 0,
          "y": 2,
          "w": 40,
          "h": 7,
          "state": {
            "storage": {
              "html": "<h2 style=\"text-align: left;\">How To Use</h2><p style=\"text-align: left;\">Congressional Committees produce different types of documents, this widget exposes them as a hierarchy:</p><p style=\"text-align: left;\">Congress -&gt; Chamber -&gt; Committee -&gt; Subcommittee -&gt; Document Type</p><p style=\"text-align: left;\">When no subcommittee, the documents reflect the parent committee.</p><p style=\"text-align: left;\">Some committee meetings are only available as video, events producing no documents are omitted. <a target=\"_blank\" rel=\"noopener noreferrer nofollow\" class=\"obb-hyper-link\" href=\"http://Congress.gov\">Congress.gov</a> includes files that are not properly encoded at the source, and those will result in \"Failed to load PDF file.\"</p>"
            }
          },
          "groups": []
        }
      ]
    }
