    "table-detail": {
      "id": "table-detail",
      "name": "Table Detail",
      "layout": [
        {
          "i": "oecd_utils_get_table_detail_custom_obb",
          "x": 0,
          "y": 2,
          "w": 40,
          "h": 25,
          "state": {
            "params": {
              "table_id": "DF_PRICES_ALL"
            }
          },
          "groups": []
        }
      ]
    }
  },
  "groups": [
    {"name": "Group 1", "type": "param", "paramName": "symbol", "defaultValue": "DF_CLI::LI"}
  ]
}]
