[{
  "name": "OECD Explorer",
  "img": "https://upload.wikimedia.org/wikipedia/commons/thumb/a/ab/Logo_OECD_2022.svg/500px-Logo_OECD_2022.svg.png",
  "img_dark": "https://upload.wikimedia.org/wikipedia/commons/thumb/a/ab/Logo_OECD_2022.svg/500px-Logo_OECD_2022.svg.png",
  "img_light": "https://upload.wikimedia.org/wikipedia/commons/thumb/a/ab/Logo_OECD_2022.svg/500px-Logo_OECD_2022.svg.png",
